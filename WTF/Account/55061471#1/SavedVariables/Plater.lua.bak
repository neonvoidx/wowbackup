["Nameplate Created"] = "function (self, unitId, unitFrame, envTable)\n    if (not Plater.PlayerCurrentTargetGUID) then\n        unitFrame.unitName:Hide()\n    else\n        if (unitFrame.namePlateIsTarget) then\n            unitFrame.unitName:Show()\n        else\n            unitFrame.unitName:Hide()\n        end\n    end\nend\n\n\n",
