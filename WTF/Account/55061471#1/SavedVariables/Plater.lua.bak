["Nameplate Updated"] = "function (self, unitId, unitFrame, envTable, modTable)\n    if unitFrame.ActorType == \"friendlyplayer\" then\n        unitFrame.BuffFrame:Hide()\n        unitFrame.BuffFrame2:Hide()\n    end\n    \nend",
},
