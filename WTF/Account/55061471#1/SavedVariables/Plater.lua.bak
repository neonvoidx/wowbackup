["script_data"] = {
{
["ConstructorCode"] = "function (self, unitId, unitFrame, envTable)\n    \n    self.pandemicGlow = self.pandemicGlow or Plater.CreateIconGlow (self)\n    envTable.pandemicGlow = self.pandemicGlow\n    \n    \nend\n\n\n",
