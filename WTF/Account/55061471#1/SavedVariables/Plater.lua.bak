["Revision"] = 36,
["Options"] = {
},
["Author"] = "Kastfall-Azralon",
["Desc"] = "When a mob is attacking you, force show the threat color. For tanks, force threat color if the mob is not attacking you.",
["Prio"] = 99,
["Name"] = "Force Threat Color",
["PlaterCore"] = 1,
["version"] = 2,
["LastHookEdited"] = "",
["semver"] = "1.0.1",
},
{
["OptionsValues"] = {
["specialColorsForNonInterruptibleEnabled"] = false,
["specialColorsEnabled"] = false,
["specialColors"] = {
